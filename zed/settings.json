{
  "cli_default_open_behavior": "new_window",
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "file_scan_exclusions": ["**/.yarn", "**/LanguageData"],
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        }
      },
      "enable_lsp_tasks": true
    }
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    },
    "opencode": {
      "type": "registry",
      "default_mode": "plan",
      "default_config_options": {
        "mode": "plan"
      },
      "favorite_config_option_values": {
        "model": [
          "github-copilot/claude-opus-4.7",
          "github-copilot/gpt-5.5",
          "openai/gpt-5.5",
          "github-copilot/claude-sonnet-4.6",
          "github-copilot/claude-opus-4.6"
        ]
      }
    }
  },
  "tab_size": 2,
  "agent": {
    "flexible": false,
    "default_width": 8,
    "dock": "left",
    "tool_permissions": {
      "default": "allow"
    },
    "inline_assistant_model": {
      "provider": "openai",
      "model": "gpt-5.4-mini"
    },
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.5"
    }
  },
  "agent_buffer_font_size": 16,
  "buffer_font_size": 17,
  "ui_font_size": 18,
  "agent_ui_font_size": 18,
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false
  },
  "buffer_font_features": {
    "calt": false
  },
  "inline_code_actions": false,
  "vim": {
    "use_system_clipboard": "always",
    "default_mode": "normal"
  },
  "use_system_path_prompts": false,
  "use_system_prompts": false,
  "pane_split_direction_vertical": "right",
  "pane_split_direction_horizontal": "down",
  "current_line_highlight": "none",
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Minimal Fedu Github"
  },
  "use_smartcase_search": true,
  "vim_mode": true,
  "cursor_blink": false,
  "relative_line_numbers": "enabled",
  "ui_font_family": "CommitMono",
  "buffer_font_family": "CommitMono",
  "ui_font_weight": 400,
  "buffer_line_height": {
    "custom": 1.75
  },
  "buffer_font_weight": 200,
  "buffer_font_fallbacks": ["nonicons"],
  "diagnostics": {
    "inline": {
      "enabled": true,
      "max_severity": "warning"
    },
    "include_warnings": true
  },
  "active_pane_modifiers": {
    "border_size": 1.75
  },
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  "completions": {
    "words": "disabled"
  },
  "scrollbar": {
    "git_diff": false
  },
  "format_on_save": "on",
  "languages": {
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "language_servers": ["!deno", "!typescript-language-server", "..."]
    },
    "TypeScript": {
      "formatter": "auto",
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "language_servers": [
        "!deno",
        "!typescript-language-server",
        "!vtsls",
        "..."
      ]
    },
    "TSX": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "language_servers": [
        "!deno",
        "!typescript-language-server",
        "!vtsls",
        "..."
      ]
    },
    "http": {
      "enable_language_server": false
    },
    "JSON": {
      "formatter": "language_server"
    }
  },
  "snippet_sort_order": "top",
  "indent_guides": {
    "enabled": false
  },
  "search": {
    "regex": true
  },
  "seed_search_query_from_cursor": "selection",
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false
  },
  "edit_predictions": {
    "provider": "copilot",
    "mode": "subtle"
  },
  "show_edit_predictions": true,
  "file_types": {
    "C++": ["mm", "m"]
  },
  "which_key": {
    "enabled": true
  },
  "unstable.ui_density": "compact",
  "gutter": {
    "min_line_number_digits": 0
  },
  "file_finder": {
    "file_icons": false,
    "include_channels": true,
    "modal_max_width": "medium"
  },
  "document_folding_ranges": "on"
}
